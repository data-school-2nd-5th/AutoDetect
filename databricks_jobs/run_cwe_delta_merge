import os
import sys
from urllib.parse import urlparse
from urllib.request import urlopen


def current_bindings() -> dict[str, str]:
    try:
        raw = dbutils.notebook.entry_point.getCurrentBindings()
    except Exception:
        return {}

    try:
        return {str(k): str(v) for k, v in raw.items()}
    except Exception:
        try:
            return {str(item.getKey()): str(item.getValue()) for item in raw.entrySet()}
        except Exception:
            return {}


def resolve_param(name: str, default: str = "") -> str:
    bindings = current_bindings()
    if name in bindings and bindings[name]:
        return bindings[name]

    try:
        value = dbutils.widgets.getArgument(name, default)
        if value:
            return value
    except Exception:
        pass

    return default


def normalize_path(raw_value: str) -> str:
    normalized = (raw_value or "").strip()
    if len(normalized) >= 2:
        if normalized[0] == normalized[-1] and normalized[0] in {"'", '"'}:
            normalized = normalized[1:-1].strip()
    return normalized


source_xml_path = normalize_path(resolve_param("source_xml_path", ""))
source_version_id = resolve_param("source_version_id", "")
target_table = resolve_param("target_table", "3dt2ndteam5.cwe.cwe_weaknesses")

dbutils.widgets.text("source_xml_path", source_xml_path)
dbutils.widgets.text("source_version_id", source_version_id)
dbutils.widgets.text("target_table", target_table)

